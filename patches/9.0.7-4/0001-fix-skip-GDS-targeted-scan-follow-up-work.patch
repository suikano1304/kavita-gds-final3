diff --git a/Kavita.Services.Tests/ScannerServiceTests.cs b/Kavita.Services.Tests/ScannerServiceTests.cs
index eaca8d852..2e080af85 100644
--- a/Kavita.Services.Tests/ScannerServiceTests.cs
