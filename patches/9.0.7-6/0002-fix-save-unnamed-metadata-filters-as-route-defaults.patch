Subject: [PATCH] fix: save unnamed metadata filters as route defaults

---
 .../src/app/_resolvers/url-filter.resolver.ts   |  4 ++--
 .../metadata-filter.component.html              |  3 +--
 .../metadata-filter.component.ts                | 10 +++++++++-
 .../_services/filter-utilities.service.ts       | 17 +++++++++++++++++
 UI/Web/src/assets/langs/en.json                 |  1 +
 UI/Web/src/assets/langs/ko.json                 |  1 +
 6 files changed, 31 insertions(+), 5 deletions(-)

diff --git a/UI/Web/src/app/_resolvers/url-filter.resolver.ts b/UI/Web/src/app/_resolvers/url-filter.resolver.ts
index 9dbf786e0..422608cd2 100644
--- a/UI/Web/src/app/_resolvers/url-filter.resolver.ts
+++ b/UI/Web/src/app/_resolvers/url-filter.resolver.ts
@@ -1,6 +1,6 @@
 import { Injectable, inject } from "@angular/core";
 import {ActivatedRouteSnapshot, Resolve, RouterStateSnapshot} from "@angular/router";
-import {Observable, of} from "rxjs";
+import {Observable} from "rxjs";
 import {FilterV2} from "../_models/metadata/v2/filter-v2";
 import {FilterUtilitiesService} from "../shared/_services/filter-utilities.service";
 
@@ -16,7 +16,7 @@ export class UrlFilterResolver implements Resolve<any> {
 
 
   resolve(route: ActivatedRouteSnapshot, state: RouterStateSnapshot): Observable<FilterV2 | null> {
-    if (!state.url.includes('?')) return of(null);
+    if (!state.url.includes('?')) return this.filterUtilitiesService.getDefaultFilterForRoute(state.url);
     return this.filterUtilitiesService.decodeFilter(state.url.split('?')[1]);
   }
 }
diff --git a/UI/Web/src/app/metadata-filter/metadata-filter.component.html b/UI/Web/src/app/metadata-filter/metadata-filter.component.html
index 20e30b273..1ed768299 100644
--- a/UI/Web/src/app/metadata-filter/metadata-filter.component.html
+++ b/UI/Web/src/app/metadata-filter/metadata-filter.component.html
@@ -80,7 +80,7 @@
     </div>
     <div class="col-md-2 col-sm-6 mt-4 pt-2">
       <div class="d-flex flex-grow-1"> <!-- TODO: How can we make this wider (col-12, old behv) if no extra buttons are present -->
-        <button class="btn btn-primary" (click)="save()" [disabled]="filterSettings().saveDisabled || !this.sortGroup.get('name')?.value">
+        <button class="btn btn-primary" (click)="save()" [disabled]="filterSettings().saveDisabled">
           <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
           {{t('save')}}
         </button>
@@ -90,4 +90,3 @@
   </ng-template>
 </ng-container>
 
-
diff --git a/UI/Web/src/app/metadata-filter/metadata-filter.component.ts b/UI/Web/src/app/metadata-filter/metadata-filter.component.ts
index 350bb21c3..7b1de0270 100644
--- a/UI/Web/src/app/metadata-filter/metadata-filter.component.ts
+++ b/UI/Web/src/app/metadata-filter/metadata-filter.component.ts
@@ -232,7 +232,15 @@ export class MetadataFilterComponent<TFilter extends number = number, TSort exte
 
   save() {
     if (!this.filterV2) return;
-    this.filterV2.name = this.sortGroup.get('name')?.value;
+    this.filterV2.name = this.sortGroup.get('name')?.value?.trim() || '';
+    if (this.filterV2.name === '') {
+      this.filterUtilitiesService.saveDefaultFilterForCurrentRoute(this.filterV2).subscribe(() => {
+        this.toastr.success(translate('toasts.default-filter-updated'));
+        this.apply();
+      });
+      return;
+    }
+
     this.filterService.saveFilter(this.filterV2).subscribe(() => {
       this.toastr.success(translate('toasts.smart-filter-updated'));
       this.apply();
diff --git a/UI/Web/src/app/shared/_services/filter-utilities.service.ts b/UI/Web/src/app/shared/_services/filter-utilities.service.ts
index 6b5656c68..317b01055 100644
--- a/UI/Web/src/app/shared/_services/filter-utilities.service.ts
+++ b/UI/Web/src/app/shared/_services/filter-utilities.service.ts
@@ -41,6 +41,7 @@ export interface FieldOption<T extends number> {
     providedIn: 'root'
 })
 export class FilterUtilitiesService {
+  private static readonly defaultFilterStoragePrefix = 'kavita--metadata-filter-default--';
 
   private readonly router = inject(Router);
   private readonly metadataService = inject(MetadataService);
@@ -79,6 +80,22 @@ export class FilterUtilitiesService {
     }));
   }
 
+  saveDefaultFilterForCurrentRoute(filter: FilterV2 | undefined) {
+    return this.encodeFilter(filter).pipe(tap(encodedFilter => {
+      localStorage.setItem(this.getDefaultFilterStorageKey(window.location.pathname), encodedFilter);
+    }));
+  }
+
+  getDefaultFilterForRoute(url: string) {
+    const encodedFilter = localStorage.getItem(this.getDefaultFilterStorageKey(url));
+    if (!encodedFilter) return of(null);
+    return this.decodeFilter(encodedFilter);
+  }
+
+  private getDefaultFilterStorageKey(url: string) {
+    return FilterUtilitiesService.defaultFilterStoragePrefix + url.split('?')[0];
+  }
+
   /**
    * Applies and redirects to the passed page with the filter encoded (Series only)
    * @param page
