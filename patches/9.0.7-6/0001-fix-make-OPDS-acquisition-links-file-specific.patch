+    private async Task<MangaFile> AddSecondFileToChapter(DataContext context, int chapterId, int pages = 17, long bytes = 2048)
+    {
+        var file = new MangaFile
+        {
+            ChapterId = chapterId,
+            FilePath = Path.Join(Path.GetDirectoryName(_testFilePath)!, "test-second.cbz"),
+            FileName = "test-second",
+            Format = MangaFormat.Archive,
+            Pages = pages,
+            Bytes = bytes,
+            Extension = ".cbz",
+            Created = DateTime.Now,
+            CreatedUtc = DateTime.UtcNow,
+            LastModified = DateTime.Now,
+            LastModifiedUtc = DateTime.UtcNow
+        };
+
+        context.MangaFile.Add(file);
+        await context.SaveChangesAsync();
+        return file;
+    }
+
+    private static FeedLink GetAcquisitionLink(FeedEntry entry)
+    {
+        var link = entry.Links.SingleOrDefault(l => l.Rel == FeedLinkRelation.Acquisition);
+        Assert.NotNull(link);
+        return link;
+    }
