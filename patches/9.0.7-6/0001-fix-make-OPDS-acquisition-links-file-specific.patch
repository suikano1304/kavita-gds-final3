+    /// <summary>
+    /// Downloads a specific OPDS file for a chapter (user must have download permission)
+    /// </summary>
+    /// <param name="apiKey">User's API Key</param>
+    /// <param name="seriesId"></param>
+    /// <param name="volumeId"></param>
+    /// <param name="chapterId"></param>
+    /// <param name="mangaFileId"></param>
+    /// <param name="filename">Not used. Only for OPDS clients to allow download links</param>
+    /// <returns></returns>
+    [ChapterAccess]
+    [Authorize(PolicyGroups.DownloadPolicy)]
+    [HttpGet("{apiKey}/series/{seriesId}/volume/{volumeId}/chapter/{chapterId}/file/{mangaFileId}/download/{filename}")]
+    public async Task<ActionResult> DownloadSpecificFile(string apiKey, int seriesId, int volumeId, int chapterId,
+        int mangaFileId, string filename)
+    {
+        var files = await unitOfWork.ChapterRepository.GetFilesForChapterAsync(chapterId);
+        var mangaFile = files.FirstOrDefault(file => file.Id == mangaFileId);
+        if (mangaFile == null) return NotFound();
+
+        return PhysicalFile(mangaFile.FilePath, downloadService.GetContentTypeFromFile(mangaFile.FilePath),
+            Path.GetFileName(mangaFile.FilePath), true);
+    }
+
