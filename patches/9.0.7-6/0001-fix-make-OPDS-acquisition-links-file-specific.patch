+    [Fact]
+    public async Task GetItemsFromChapter_ReturnsDistinctEntryPerFile()
+    {
+        var (unitOfWork, context, mapper) = await CreateDatabase();
+        var (opdsService, _) = SetupService(unitOfWork, mapper);
+        var user = await SetupSeriesAndUser(context, unitOfWork);
+        var secondFile = await AddSecondFileToChapter(context, 1);
+
+        var feed = await opdsService.GetItemsFromChapter(new OpdsItemsFromCompoundEntityIdsRequest
+        {
+            ApiKey = user.GetOpdsAuthKey(),
+            Prefix = OpdsService.DefaultApiPrefix,
+            BaseUrl = string.Empty,
+            UserId = user.Id,
+            Preferences = await unitOfWork.UserRepository.GetOpdsPreferences(user.Id),
+            SeriesId = 1,
+            VolumeId = 1,
+            ChapterId = 1,
+            PageNumber = OpdsService.FirstPageNumber
+        });
+
+        Assert.Equal(2, feed.Entries.Count);
+        Assert.Equal(2, feed.Entries.Select(e => e.Id).Distinct().Count());
+
+        var secondEntry = feed.Entries.Single(e => e.Id == secondFile.Id.ToString());
+        var acquisition = GetAcquisitionLink(secondEntry);
+
+        Assert.Contains($"/chapter/1/file/{secondFile.Id}/download/test-second.cbz", acquisition.Href);
+        Assert.Equal(17, acquisition.TotalPages);
+        Assert.Equal("2 KB", secondEntry.Extent);
+        Assert.Contains("File Type: x-cbz - 2 KB", secondEntry.Summary);
+
+        var pageStream = secondEntry.Links.Single(l => l.Rel == FeedLinkRelation.Stream);
+        Assert.Equal(17, pageStream.TotalPages);
+    }
+
