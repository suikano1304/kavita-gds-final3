+using Kavita.Server.Controllers;
+
+namespace Kavita.Server.Tests.Controllers;
+
+public class OpdsControllerTests
+{
+    [Theory]
+    [InlineData("Panels/1.0", true, false)]
+    [InlineData("Panels/1.0", false, false)]
+    [InlineData("KOReader/2026", true, true)]
+    [InlineData("KOReader/2026", false, false)]
+    [InlineData("Other OPDS Client", true, true)]
+    [InlineData("Other OPDS Client", false, false)]
+    public void ShouldSaveOpdsPageProgress_RespectsPanelsAndSaveProgress(string userAgent, bool saveProgress,
+        bool expected)
+    {
+        Assert.Equal(expected, OpdsController.ShouldSaveOpdsPageProgress(userAgent, saveProgress));
+    }
+}
